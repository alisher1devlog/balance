generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SubscriptionPlan {
  id          String    @id @default(uuid()) @db.Uuid
  duration    Int
  price       Decimal   @db.Decimal(15, 2)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  name        String    @db.VarChar(50)
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  payments    Payment[]
  owners      User[]

  @@map("subscription_plans")
}

model Payment {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  planId    String           @map("plan_id") @db.Uuid
  amount    Decimal          @db.Decimal(10, 2)
  startDate DateTime         @map("start_date")
  endDate   DateTime         @map("end_date")
  createdAt DateTime         @default(now()) @map("created_at")
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  user      User             @relation(fields: [userId], references: [id])

  @@map("payments")
}

model User {
  id           String            @id @default(uuid()) @db.Uuid
  marketId     String?           @map("market_id") @db.Uuid
  fullName     String            @map("full_name") @db.VarChar(100)
  phone        String?           @unique @db.VarChar(20)
  password     String            @db.VarChar(255)
  role         Role
  planId       String?           @map("plan_id") @db.Uuid
  subEndDate   DateTime?         @map("sub_end_date")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  email        String            @unique
  status       UserStatus        @default(ACTIVE)
  contracts    Contract[]
  ownerMarkets Market[]          @relation("OwnerMarkets")
  payments     Payment[]
  transactions Transaction[]
  workMarket   Market?           @relation("WorkMarket", fields: [marketId], references: [id])
  plan         SubscriptionPlan? @relation(fields: [planId], references: [id])

  @@map("users")
}

model Market {
  id         String       @id @default(uuid()) @db.Uuid
  ownerId    String       @map("owner_id") @db.Uuid
  address    String?      @db.VarChar(255)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  name       String       @db.VarChar(100)
  phone      String?      @db.VarChar(20)
  status     MarketStatus @default(PENDING)
  categories Category[]
  contracts  Contract[]
  customers  Customer[]
  owner      User         @relation("OwnerMarkets", fields: [ownerId], references: [id])
  products   Product[]
  workers    User[]       @relation("WorkMarket")

  @@map("markets")
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  marketId  String    @map("market_id") @db.Uuid
  name      String    @db.VarChar(100)
  imageUrl  String?   @map("image_url")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  market    Market    @relation(fields: [marketId], references: [id])
  products  Product[]

  @@unique([marketId, name])
  @@map("categories")
}

model Product {
  id            String         @id @default(uuid()) @db.Uuid
  marketId      String         @map("market_id") @db.Uuid
  categoryId    String         @map("category_id") @db.Uuid
  name          String         @db.VarChar(200)
  description   String?
  imageUrl      String?        @map("image_url")
  stock         Int            @default(0)
  basePrice     Decimal        @map("base_price") @db.Decimal(15, 2)
  status        ProductStatus  @default(ACTIVE)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  contractItems ContractItem[]
  category      Category       @relation(fields: [categoryId], references: [id])
  market        Market         @relation(fields: [marketId], references: [id])

  @@index([marketId])
  @@index([categoryId])
  @@map("products")
}

model Customer {
  id            String         @id @default(uuid()) @db.Uuid
  marketId      String         @map("market_id") @db.Uuid
  fullName      String         @map("full_name") @db.VarChar(100)
  phone         String         @db.VarChar(20)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  address       String?        @db.VarChar(255)
  birthDate     DateTime?      @map("birth_date")
  note          String?
  passportSeria String?        @unique @map("passport_seria") @db.VarChar(20)
  contracts     Contract[]
  market        Market         @relation(fields: [marketId], references: [id])
  documents     Document[]
  notifications Notification[]

  @@unique([marketId, phone])
  @@index([marketId])
  @@map("customers")
}

model Contract {
  id              String         @id @default(uuid()) @db.Uuid
  contractNumber  String         @unique @map("contract_number")
  marketId        String         @map("market_id") @db.Uuid
  customerId      String         @map("customer_id") @db.Uuid
  staffId         String         @map("staff_id") @db.Uuid
  termMonths      Int            @map("term_months")
  downPayment     Decimal        @default(0) @map("down_payment") @db.Decimal(15, 2)
  totalAmount     Decimal        @map("total_amount") @db.Decimal(15, 2)
  monthlyAmount   Decimal        @map("monthly_amount") @db.Decimal(15, 2)
  paidAmount      Decimal        @default(0) @map("paid_amount") @db.Decimal(15, 2)
  remainAmount    Decimal        @map("remain_amount") @db.Decimal(15, 2)
  startDate       DateTime       @map("start_date")
  endDate         DateTime       @map("end_date")
  status          ContractStatus @default(DRAFT)
  note            String?
  signToken       String?        @unique @map("sign_token") @db.VarChar(100)
  signTokenExpiry DateTime?      @map("sign_token_expiry")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  items           ContractItem[]
  customer        Customer       @relation(fields: [customerId], references: [id])
  market          Market         @relation(fields: [marketId], references: [id])
  staff           User           @relation(fields: [staffId], references: [id])
  installments    Installment[]
  notifications   Notification[]
  signature       Signature?
  transactions    Transaction[]

  @@index([marketId])
  @@index([customerId])
  @@index([status])
  @@map("contracts")
}

model ContractItem {
  id          String   @id @default(uuid()) @db.Uuid
  contractId  String   @map("contract_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  productName String   @map("product_name") @db.VarChar(200)
  quantity    Int      @default(1)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(15, 2)
  totalPrice  Decimal  @map("total_price") @db.Decimal(15, 2)
  contract    Contract @relation(fields: [contractId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])

  @@map("contract_items")
}

model Installment {
  id            String            @id @default(uuid()) @db.Uuid
  contractId    String            @map("contract_id") @db.Uuid
  orderIndex    Int               @map("order_index")
  dueDate       DateTime          @map("due_date")
  amount        Decimal           @db.Decimal(15, 2)
  paidAmount    Decimal           @default(0) @map("paid_amount") @db.Decimal(15, 2)
  status        InstallmentStatus @default(PENDING)
  paidAt        DateTime?         @map("paid_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  contract      Contract          @relation(fields: [contractId], references: [id])
  notifications Notification[]
  transactions  Transaction[]

  @@index([contractId])
  @@index([dueDate])
  @@index([status])
  @@map("installments")
}

model Transaction {
  id            String          @id @default(uuid()) @db.Uuid
  type          TransactionType
  amount        Decimal         @db.Decimal(15, 2)
  createdAt     DateTime        @default(now()) @map("created_at")
  contractId    String          @map("contract_id") @db.Uuid
  installmentId String?         @map("installment_id") @db.Uuid
  note          String?
  staffId       String          @map("staff_id") @db.Uuid
  contract      Contract        @relation(fields: [contractId], references: [id])
  installment   Installment?    @relation(fields: [installmentId], references: [id])
  staff         User            @relation(fields: [staffId], references: [id])

  @@index([contractId])
  @@index([createdAt])
  @@map("transactions")
}

model Signature {
  id           String   @id @default(uuid()) @db.Uuid
  contractId   String   @unique @map("contract_id") @db.Uuid
  signatureUrl String   @map("signature_url")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent")
  signedAt     DateTime @map("signed_at")
  contract     Contract @relation(fields: [contractId], references: [id])

  @@map("signatures")
}

model Notification {
  id            String              @id @default(uuid()) @db.Uuid
  customerId    String              @map("customer_id") @db.Uuid
  contractId    String?             @map("contract_id") @db.Uuid
  installmentId String?             @map("installment_id") @db.Uuid
  channel       NotificationChannel
  reason        NotificationReason
  status        NotificationStatus  @default(PENDING)
  message       String
  sentAt        DateTime?           @map("sent_at")
  error         String?
  createdAt     DateTime            @default(now()) @map("created_at")
  contract      Contract?           @relation(fields: [contractId], references: [id])
  customer      Customer            @relation(fields: [customerId], references: [id])
  installment   Installment?        @relation(fields: [installmentId], references: [id])

  @@index([customerId])
  @@index([contractId])
  @@index([installmentId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

model Document {
  id           String       @id @default(uuid()) @db.Uuid
  customerId   String       @map("customer_id") @db.Uuid
  type         DocumentType
  fileName     String       @map("file_name") @db.VarChar(255)
  fileUrl      String       @map("file_url")
  fileSize     Int?         @map("file_size")
  mimeType     String?      @map("mime_type") @db.VarChar(100)
  uploadedById String       @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at")
  customer     Customer     @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("documents")
}

enum MarketStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  EXPIRED
  PENDING
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  SELLER
  SUPERADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  EXPIRED
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ContractStatus {
  DRAFT
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  OVERDUE
}

enum InstallmentStatus {
  PENDING
  DUE
  PAID
  OVERDUE
  PARTIAL
}

enum TransactionType {
  PAYMENT
  DOWNPAYMENT
  PENALTY
  REFUND
}

enum NotificationChannel {
  SMS
  TELEGRAM
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationReason {
  INSTALLMENT_REMINDER
  INSTALLMENT_DUE
  INSTALLMENT_OVERDUE
  CONTRACT_SIGNED
  CONTRACT_CREATED
  SUBSCRIPTION_EXPIRING
}

enum DocumentType {
  PASSPORT
  SELFIE
  INCOME_PROOF
  OTHER
}
